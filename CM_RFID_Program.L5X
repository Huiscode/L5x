<Text>
<![CDATA[[MOV(0,ToolMumberInToolSet_X) ,XIO(\Program_QS100.StationControl[7].Station.Sts_MoverAtStation) ONS(OneShoot.0) MOV(RFID_Dummy.EquipmentNo,RFID_ToolRead1.EquipmentNo) ,XIC(\Program_QS100.StationControl[7].Station.Sts_MoverAtStation) XIC(RFID.InterfaceT1ReadDone) [ONS(OneShoot.1) MOV(1,ToolSet_Pointer) ,XIO(\ES01_EM31_Station31_ToolPitShuttle.StartShiftToolSet) [EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[1]) MOV(1,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[2]) MOV(2,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[3]) MOV(3,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[4]) MOV(4,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[5]) MOV(5,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[6]) MOV(6,ToolMumberInToolSet_X) ] ,XIC(\ES01_EM31_Station31_ToolPitShuttle.StartShiftToolSet) NEQ(RFID_ToolRead1.EquipmentNo,RFID_Dummy.EquipmentNo) [EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[1]) MOV(1,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[2]) MOV(2,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[3]) MOV(3,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[4]) MOV(4,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[5]) MOV(5,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,ListOfProduct_Running.ToolSet[ToolSet_Pointer].ToolNumber[6]) MOV(6,ToolMumberInToolSet_X) ,EQU(RFID_ToolRead1.EquipmentNo,Lis