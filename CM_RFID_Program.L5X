<Member Name="PalletStatus" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Grundfos pallet status
Empty  Bit0=1
OK(w.device) Bit1=1
Fault(w.device) Bit2=1
Reorder device Bit3=1
Recycle device Bit4=1
Retest device Bit5=1
Auto palletizing Bit6=1
Device out of normal flow Bit7=1
Copy pallet Bit11=1]]>
<LocalizedDescription Lang="en-US">
<![CDATA[Grundfos pallet status
Empty  Bit0=1
OK(w.device) Bit1=1
Fault(w.device) Bit2=1
Reorder device Bit3=1
Recycle device Bit4=1
Retest device Bit5=1
