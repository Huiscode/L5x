<Rung Number="13" Type="N">
<Text>
<![CDATA[LBL(BOM)CMP(ArrayPointer<=(BomLen-1))GfosSintArrayToString(IdTagDataToString,Data_IN,StartByte,8,StringOut)MOV(StringOut.LEN,Data_Out.BOM[ArrayPointer].LEN)CPS(Data_IN[StartByte],Data_Out.BOM[ArrayPointer].DATA[0],8);]]>
