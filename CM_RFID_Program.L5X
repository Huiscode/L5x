<Routines>
<Routine Name="MainRoutine" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[------------------
Check if RFID Module is online and running on Ethernet
Set RFID Module in RUN mode 
------------------]]>
<LocalizedComment Lang="en-US">
<![CDATA[------------------
Check if RFID Module is online and running on Ethernet
Set RFID Module in RUN mode 
------------------]]>
</LocalizedComment>
</Comment>
<Text>
<![CDATA[[GSV(Module,Rfid_K01_L02,EntryStatus,InterfaceEntry) AOI_ModuleStatus(InterfaceStatus,InterfaceEntry) ,XIC(InterfaceStatus.Runnig) OTE(Rfid_K01_L02:O.Run) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[-------------------------------------------------------------
RFID Module/Channel in ERROR State
-------------------------------------------------------------]]>
<LocalizedComment Lang="en-US">
<![CDATA[-------------------------------------------------------------
RFID Module/Channel in ERROR State
-------------------------------------------------------------]]>
</LocalizedComment>
</Comment>
<Text>
<![CDATA[[XIO(Rfid_K01_L02:I.Run) ,XIO(Rfid_K01_L02:O.Run) ,NEQ(Rfid_K01_L02:I.Fault,0) ]OTE(RFID.InterfaceError);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[JSR(SR10_CommonProgram_Transceiver1,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[JSR(SR11_CommonProgram_Transceiver2,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[JSR(SR01_Transceiver1UserSetup,0);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[JSR(SR02_Transceiver1ReadWrite,0);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[JSR(SR03_Transceiver2UserSetup,0);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[JSR(SR04_Transceiver2ReadWrite,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
