<Routines>
<Routine Name="Logic" Type="RLL">
<Description>
<![CDATA[Converting array of 20 SINT to one STRING]]>
<LocalizedDescription Lang="en-US">
<![CDATA[Converting array of 20 SINT to one STRING]]>
</LocalizedDescription>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[COP(DummyString,StringOut,1)MOV(StartPos,Pointer)ADD(StartPos,Length,EndPos)CLR(Counter);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[LBL(Search)LES(Pointer,2000)LES(Pointer,EndPos)NEQ(SINTArray[Pointer],0)ADD(Pointer,1,Pointer)ADD(Counter,1,Counter)JMP(Search);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[MOV(Counter,StringOut.LEN)COP(SINTArray[StartPos],StringOut.DATA[0],Counter);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
