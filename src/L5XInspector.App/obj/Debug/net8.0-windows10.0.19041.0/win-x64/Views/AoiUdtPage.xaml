<Page x:ConnectionId='1'
    x:Class="L5XInspector.App.Views.AoiUdtPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:L5XInspector.App">

    <Grid Padding="24" RowDefinitions="Auto,*" ColumnDefinitions="2*,3*" ColumnSpacing="16" RowSpacing="16">
        <TextBlock Text="AOI / UDT Explorer" FontSize="24" FontWeight="SemiBold" Grid.ColumnSpan="2" />
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Definitions" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='13' Content="All"                     />
                    <Button x:ConnectionId='14' Content="AOIs"                     />
                    <Button x:ConnectionId='15' Content="UDTs"                     />
                    <Button x:ConnectionId='16' Content="Tags"                      />
                </StackPanel>
                <ListView x:ConnectionId='7' x:Name="AoiUdtList"
                                                                           
                                                               >
                    <ListView.ItemTemplate>
                        <DataTemplate                              >
                            <StackPanel x:ConnectionId='9' Spacing="2" Padding="4">
                                <TextBlock x:ConnectionId='10'                      FontWeight="SemiBold" />
                                <TextBlock x:ConnectionId='11'                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:ConnectionId='12'                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Details" FontWeight="SemiBold" />
                <TextBlock x:ConnectionId='2' x:Name="DetailKind" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:ConnectionId='3' x:Name="DetailName" Text="Select an item" FontWeight="SemiBold" />
                <TextBlock x:ConnectionId='4' x:Name="DetailSummary" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:ConnectionId='5' x:Name="DetailMeta" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:ConnectionId='6' x:Name="DetailCounts" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>

