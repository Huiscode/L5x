<Page
    x:Class="L5XInspector.App.Views.AoiUdtPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:L5XInspector.App">

    <Grid Padding="24" RowDefinitions="Auto,*" ColumnDefinitions="2*,3*" ColumnSpacing="16" RowSpacing="16">
        <TextBlock Text="AOI / UDT Explorer" FontSize="24" FontWeight="SemiBold" Grid.ColumnSpan="2" />
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Definitions" FontWeight="SemiBold" />
                <ListView x:Name="AoiUdtList"
                          ItemsSource="{x:Bind local:AppState.AoiUdtItems}"
                          SelectionChanged="OnSelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:AoiUdtItem">
                            <StackPanel Spacing="2" Padding="4">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Summary}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind Meta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Details" FontWeight="SemiBold" />
                <TextBlock x:Name="DetailName" Text="Select an item" FontWeight="SemiBold" />
                <TextBlock x:Name="DetailSummary" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="DetailMeta" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
